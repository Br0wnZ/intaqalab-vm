{
  "name": "@intaqalab/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx run intaqalab:serve",
    "start:dev": "concurrently \"nx run intaqalab:serve\" \"nx run mock-data:serve\"",
    "start:mocks:app": "cross-env VITE_MOCKS_AUTH=true PROXY_TARGET=mocks nx run intaqalab:serve:mocks",
    "start:dev:mocks": "concurrently \"npm run start:mocks\" \"npm run start:mocks:app\"",
    "start:des": "nx serve intaqalab -c des",
    "start:pre": "nx serve intaqalab -c pre",
    "start:prod": "nx serve intaqalab -c production",
    "proxy:des": "cross-env PROXY_TARGET=des nx serve intaqalab -c des",
    "proxy:pre": "cross-env PROXY_TARGET=pre nx serve intaqalab -c pre",
    "proxy:pro": "cross-env PROXY_TARGET=pro nx serve intaqalab -c production",
    "build": "npx nx run intaqalab:build",
    "build:dev": "npx nx run intaqalab:build --configuration=development",
    "build:des": "npx nx run intaqalab:build --configuration=des",
    "build:pre": "npx nx run intaqalab:build --configuration=pre",
    "build:prod": "npx nx run intaqalab:build --configuration=production",
    "test": "nx test",
    "test:cicd": "echo skipping temporaly test2",
    "test:data-access:ui": "nx test data-access --ui --watch",
    "test:all": "nx run-many --target=test --projects=admin,calendar-trials,planning,trial-management,data-access,ui,pruebas,utils,shared-theme,core,wharehouse-managment --parallel=true",
    "vitest:ui": "cross-env NODE_OPTIONS='--max-old-space-size=8192' npx vitest --ui",
    "test:admin": "nx test admin",
    "test:admin:watch": "nx test admin --watch",
    "test:admin:ui": "nx test admin --ui --watch",
    "test:calendar-trials": "nx test calendar-trials",
    "test:calendar-trials:watch": "nx test calendar-trials --watch",
    "test:calendar-trials:ui": "nx test calendar-trials --ui --watch",
    "test:planning": "nx test planning",
    "test:planning:watch": "nx test planning --watch",
    "test:planning:ui": "nx test planning --ui --watch",
    "test:trial-management": "nx test trial-management",
    "test:trial-management:watch": "nx test trial-management --watch",
    "test:trial-management:ui": "nx test trial-management --ui --watch",
    "test:event-log:ui": "nx test event-log --ui --watch",
    "test:master-data:ui": "nx test master-data --ui --watch",
    "test:core": "nx test core",
    "test:core:watch": "nx test core --watch",
    "test:core:ui": "nx test core --ui --watch",
    "test:data-access": "nx test data-access",
    "test:data-access:watch": "nx test data-access --watch",
    "test:ui": "nx test ui",
    "test:ui:watch": "nx test ui --watch",
    "test:ui:ui": "nx test ui --ui --watch",
    "test:utils": "nx test utils",
    "test:utils:watch": "nx test utils --watch",
    "test:utils:ui": "nx test utils --ui --watch",
    "test:pruebas": "nx test pruebas",
    "test:pruebas:watch": "nx test pruebas --watch",
    "test:pruebas:ui": "nx test pruebas --ui --watch",
    "test:shared-theme": "nx test shared-theme",
    "test:shared-theme:watch": "nx test shared-theme --watch",
    "test:shared-theme:ui": "nx test shared-theme --ui --watch",
    "test:wharehouse-managment": "nx test wharehouse-managment",
    "test:wharehouse-managment:watch": "nx test wharehouse-managment --watch",
    "test:wharehouse-managment:ui": "nx test wharehouse-managment --ui --watch",
    "start:mocks": "nx run mock-data:serve",
    "format": "prettier --write .",
    "affected:lint": "npx nx affected --target=lint",
    "lint:all": "npx nx run-many --target=lint --outputStyle=stream",
    "verify": "bash ./tools/verify/verify.sh",
    "i18n:check": "node ./tools/verify/check-i18n.mjs",
    "i18n:check:update-baseline": "node ./tools/verify/check-i18n.mjs --update-baseline",
    "test:coverage": "npx vitest run --coverage",
    "test:coverage:ui": "cross-env NODE_OPTIONS='--max-old-space-size=8192' npx vitest --ui --coverage",
    "test:execution": "nx test execution",
    "test:execution:watch": "nx test execution --watch",
    "test:execution:ui": "nx test execution --ui --watch",
    "test:execution:coverage": "nx test execution --coverage",
    "test:coverage:all": "npx nx run-many --target=test --codeCoverage=true",
    "coverage:merge": "node scripts/merge-coverage.js",
    "coverage:full": "npm run test:coverage:all && npm run coverage:merge",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.1.5",
